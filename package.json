{
  "name": "lumina",
  "version": "0.1.0",
  "description": "Privacy-first AI desktop companion",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "npm run rebuild:native && electron-vite dev",
    "build": "npm run rebuild:native && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "npm rebuild better-sqlite3 && vitest run",
    "test:watch": "npm rebuild better-sqlite3 && vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:smoke": "playwright test smoke.spec.ts",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,@paymoapp/active-window",
    "benchmark:retrieval": "tsx scripts/benchmark-retrieval.ts",
    "logs": "tail -f \"$HOME/Library/Logs/Lumina/lumina-main.log\"",
    "kill": "pkill -f Electron || true",
    "dev:fresh": "npm run kill && npm run dev"
  },
  "dependencies": {
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "^1.2.1",
    "@paymoapp/active-window": "^2.0.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^9.4.3",
    "electron-ollama": "^0.1.25",
    "langfuse": "^3.38.6",
    "mathjs": "^15.1.1",
    "node-cron": "^4.2.1",
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.1",
    "electron-vite": "^2.2.0",
    "happy-dom": "^20.8.9",
    "jest-axe": "^10.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "overrides": {
    "tar": "^7.5.11"
  }
}
