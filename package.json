{
  "name": "lumina",
  "version": "0.1.0",
  "description": "Privacy-first AI desktop companion",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "npm run rebuild:native && electron-vite dev",
    "build": "npm run rebuild:native && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "npm rebuild better-sqlite3 && vitest run",
    "test:watch": "npm rebuild better-sqlite3 && vitest",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.1",
    "electron-vite": "^2.2.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
